			mouseExit { setitemcolor scoreColumn bordercolor .5 .5 .5 .5 }
		}

		itemDef
		{
			name killsColumn
			group grpColumn
			rect 490 80 122 335
			style WINDOW_STYLE_FILLED
			border 1
			backcolor 0 0 0 0
			bordersize 1
			bordercolor .5 .5 .5 .5
			visible 1
			decoration
		}

		itemDef
		{
			name kills
			group grpTabs
			text "@MPUI_KILLS_PRE"
			type ITEM_TYPE_BUTTON
			textscale 0.25
			textfont	UI_FONT_NORMAL
			style WINDOW_STYLE_FILLED
			border 1
			bordercolor .1 .1 .1 .25
			rect 490 65 122 15
			textalign ITEM_ALIGN_LEFT
			textalignx 2		// center
			textaligny 10
			forecolor 1 1 1 1
			backcolor OPTIONS_HEADING_JOIN_COLOR
			visible 1
			action
			{
