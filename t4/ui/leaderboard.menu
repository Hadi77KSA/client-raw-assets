			mouseEnter { setitemcolor clientsColumn bordercolor 1 1 1 1 ; play "mouse_over" }
			mouseExit { setitemcolor clientsColumn bordercolor .5 .5 .5 .5 }
		}

		itemDef
		{
			name timeColumn
			group grpColumn
			rect 340 80 69 335
			style WINDOW_STYLE_FILLED
			border 1
			backcolor 0 0 0 0
			bordersize 1
			bordercolor .5 .5 .5 .5
			visible 1
			decoration
		}

		itemDef
		{
			name time
			group grpTabs
			text "@PLUTONIUM_MENU_ROUND_TIME"
			type ITEM_TYPE_BUTTON
			textscale 0.25
			textfont	UI_FONT_NORMAL
			style WINDOW_STYLE_FILLED
			border 1
			bordercolor .1 .1 .1 .25
			rect 340 65 69 15
			textalign ITEM_ALIGN_LEFT
			textalignx 2		// center
			textaligny 10
			forecolor 1 1 1 1
			backcolor OPTIONS_HEADING_JOIN_COLOR
			visible 1
			action
			{
				play "mouse_click" ;
				setitemcolor grpTabs backcolor .3 .5 .2 .3 ;
				setitemcolor time backcolor .1 .2 .37 1 ;
				setitemcolor grpColumn backcolor 0 0 0 0 ;
				setitemcolor timeColumn backcolor 0 0 0.4 .15
			}
			mouseEnter { setitemcolor timeColumn bordercolor 1 1 1 1 ; play "mouse_over" }
			mouseExit { setitemcolor timeColumn bordercolor .5 .5 .5 .5 }
		}

		itemDef
		{
			name scoreColumn
			group grpColumn
			rect 410 80 79 335
			style WINDOW_STYLE_FILLED
			border 1
			backcolor 0 0 0 0
			bordersize 1
			bordercolor .5 .5 .5 .5
			visible 1
			decoration
		}

		itemDef
		{
			name score
			group grpTabs
			text "@MPUI_SCORE_PRE"
			type ITEM_TYPE_BUTTON
			textscale 0.25
			textfont	UI_FONT_NORMAL
			style WINDOW_STYLE_FILLED
			border 1
			bordercolor .1 .1 .1 .25
			rect 410 65 79 15
			textalign ITEM_ALIGN_LEFT
			textalignx 2		// center
			textaligny 10
			forecolor 1 1 1 1
			backcolor OPTIONS_HEADING_JOIN_COLOR
			visible 1
			action
			{
				play "mouse_click" ;
				setitemcolor grpTabs backcolor .3 .5 .2 .3 ;
				setitemcolor score backcolor .1 .2 .37 1 ;
