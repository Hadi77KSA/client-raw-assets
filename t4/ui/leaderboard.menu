				setitemcolor round backcolor .1 .2 .37 1 ;
				setitemcolor grpColumn backcolor 0 0 0 0 ;
				setitemcolor roundColumn backcolor 0 0 0.4 .15
			}
			mouseEnter { setitemcolor roundColumn bordercolor 1 1 1 1 ; play "mouse_over" }
			mouseExit { setitemcolor roundColumn bordercolor .5 .5 .5 .5 }
		}

		itemDef
		{
			name clientsColumn
			group grpColumn
			rect 320 80 19 335
			style WINDOW_STYLE_FILLED
			border 1
			backcolor 0 0 0 0
			bordersize 1
			bordercolor .5 .5 .5 .5
			visible 1
			decoration
		}

		itemDef
		{
			name clients
			group grpTabs
			text "#"
			type ITEM_TYPE_BUTTON
			textscale 0.25
			textfont	UI_FONT_NORMAL
			style WINDOW_STYLE_FILLED
			border 1
			bordercolor .1 .1 .1 .25
			rect 320 65 19 15
			textalign ITEM_ALIGN_LEFT
			textalignx 2		// center
			textaligny 10
			forecolor 1 1 1 1
			backcolor OPTIONS_HEADING_JOIN_COLOR
			visible 1
			action
			{
				play "mouse_click" ;
